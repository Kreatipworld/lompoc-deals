# Postgres connection string from Neon (https://neon.tech)
DATABASE_URL=

# Auth.js — generate with: openssl rand -base64 32
AUTH_SECRET=
# In dev: http://localhost:3000  In prod: https://yourdomain.com
AUTH_URL=http://localhost:3000

# Resend (https://resend.com) for transactional + digest emails
RESEND_API_KEY=

# Vercel Blob (https://vercel.com/storage/blob) for image uploads
BLOB_READ_WRITE_TOKEN=

# Cron auth — generate with: openssl rand -base64 32
CRON_SECRET=
