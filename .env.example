# Postgres connection string from Neon (https://neon.tech)
DATABASE_URL=

# Auth.js — generate with: openssl rand -base64 32
AUTH_SECRET=
# In dev: http://localhost:3000  In prod: https://yourdomain.com
AUTH_URL=http://localhost:3000

# Resend (https://resend.com) for transactional + digest emails
RESEND_API_KEY=

# Vercel Blob (https://vercel.com/storage/blob) for image uploads
BLOB_READ_WRITE_TOKEN=

# Cron auth — generate with: openssl rand -base64 32
CRON_SECRET=

# Stripe — subscription billing & Connect payouts (https://dashboard.stripe.com)
# Secret key (starts with sk_live_ or sk_test_)
STRIPE_SECRET_KEY=
# Publishable key (starts with pk_live_ or pk_test_) — safe for client-side
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
# Webhook signing secret — from Stripe Dashboard > Webhooks, or `stripe listen` output
STRIPE_WEBHOOK_SECRET=
# Price IDs for the 3 subscription tiers (create in Stripe Dashboard > Products)
# Free tier needs no price ID (handled in code without Stripe Checkout)
STRIPE_PRICE_FREE=
# Standard tier — $19.99/mo, up to 15 active deals
STRIPE_PRICE_STANDARD=
# Premium tier — $39.99/mo, unlimited deals + featured placement
STRIPE_PRICE_PREMIUM=
# Stripe Connect — platform application fee rate (0.0–1.0, e.g. 0.10 = 10%)
STRIPE_CONNECT_APPLICATION_FEE_PERCENT=
